generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String   @default("")
  password  String
  role      String   @default("student") // coordinator, teacher, student
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher       Teacher?
  student       Student?
  sentMessages  Message[]  @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Teacher {
  id        String @id @default(cuid())
  userId    String @unique
  subjects  String @default("") // comma-separated
  bio       String @default("")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability TeacherAvailability[]
  appointments Appointment[]
  classes      Class[]

  @@map("teachers")
}

model Student {
  id              String @id @default(cuid())
  userId          String @unique
  responsibleName String @default("")
  notes           String @default("")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  classStudents ClassStudent[]
  attendance    Attendance[]
  appointments  Appointment[]

  @@map("students")
}

model Class {
  id        String @id @default(cuid())
  name      String
  subject   String
  teacherId String

  teacher       Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classStudents ClassStudent[]
  appointments  Appointment[]
  tests         Test[]

  @@map("classes")
}

model ClassStudent {
  id        String @id @default(cuid())
  classId   String
  studentId String

  class    Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@map("class_students")
}

model TeacherAvailability {
  id         String @id @default(cuid())
  teacherId  String
  weekday    Int    // 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sab
  startTime  String // HH:mm
  endTime    String // HH:mm

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_availability")
}

model Appointment {
  id               String @id @default(cuid())
  classId          String
  teacherId        String
  studentId        String?
  date             String // yyyy-MM-dd
  startTime        String // HH:mm
  endTime          String // HH:mm
  recurringGroupId String?
  status           String @default("confirmed") // confirmed, cancelled, completed
  notes            String @default("")
  createdAt        DateTime @default(now())

  class          Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher        Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student        Student?       @relation(fields: [studentId], references: [id], onDelete: SetNull)
  attendance     Attendance[]
  makeUpClasses  MakeUpClass[]

  @@map("appointments")
}

model Test {
  id        String @id @default(cuid())
  classId   String
  title     String
  date      String // yyyy-MM-dd

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("tests")
}

model Attendance {
  id           String @id @default(cuid())
  studentId    String
  appointmentId String
  status       String @default("present") // present, absent, late

  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([studentId, appointmentId])
  @@map("attendance")
}

model MakeUpClass {
  id                   String @id @default(cuid())
  originalAppointmentId String
  newDate              String // yyyy-MM-dd
  newStartTime         String // HH:mm
  newEndTime           String // HH:mm
  status               String @default("scheduled") // scheduled, completed, cancelled

  originalAppointment Appointment @relation(fields: [originalAppointmentId], references: [id], onDelete: Cascade)

  @@map("make_up_classes")
}

model Holiday {
  id   String @id @default(cuid())
  name String
  date String // yyyy-MM-dd

  @@unique([date])
  @@map("holidays")
}

model Recess {
  id          String @id @default(cuid())
  startDate   String // yyyy-MM-dd
  endDate     String // yyyy-MM-dd
  description String @default("")

  @@map("recesses")
}

model Message {
  id        String   @id @default(cuid())
  senderId  String
  receiverId String
  subject   String   @default("")
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
}
