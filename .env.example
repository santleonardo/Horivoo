# ============================================================
# HORIVOO — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# Supabase — Obrigatório
# Encontre em: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# JWT — OBRIGATÓRIO em produção (não há fallback inseguro)
# Gere um segredo forte: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=substitua-por-um-segredo-aleatorio-de-no-minimo-32-caracteres
